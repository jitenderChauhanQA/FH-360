# FH360 Automation Framework — Environment Variables
# Copy this file to .env and fill in your values

# Salesforce Base URL
FH360_BASE_URL=https://firsthorizon--uat.sandbox.my.salesforce.com

# Environment (dev | staging | ci)
ENV=dev

# CSP Agent Credentials
CSP_USER=
CSP_PASS=

# Retail Banker Credentials
RETAIL_USER=
RETAIL_PASS=

# Commercial Banker Credentials
COMMERCIAL_USER=
COMMERCIAL_PASS=

# Mortgage Officer Credentials
MORTGAGE_USER=
MORTGAGE_PASS=
